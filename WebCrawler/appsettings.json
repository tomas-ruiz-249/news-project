{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"System.Net.Http.HttpClient": "Warning"
		},
		"Console": {
			"FormatterName": "simple",
			"FormatterOptions": {
				"SingleLine": true,
				"TimestampFormat": "HH:mm:ss ",
				"UseUtcTimestamp": false,
				"IncludeScopes": false,
				"ColorBehavior": "Default"
			}
		}
	}
}
